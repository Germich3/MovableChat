{
  "schemaVersion": 1,
  "id": "movablechat",
  "version": "${version}",
  "name": "Movable Chat",
  "description": "Move Chat HUD",
  "authors": [
    "Germich3"
  ],
  "contact": {
    "homepage": "https://github.com/Germich3/MovableChat",
    "sources": "https://github.com/Germich3/MovableChat"
  },
  "license": "MIT",
  "icon": "assets/movablechat/icon.png",
  "environment": "client",
  "entrypoints": {
    "main": [
      "es.germich3.movablechat.MovableChat"
    ],
    "client": [
      "es.germich3.movablechat.client.MovableChatClient"
    ],
    "modmenu": [
      "es.germich3.movablechat.client.apis.modmenu.ModMenuImpl"
    ]
  },
  "mixins": [
    "movablechat.mixins.json",
    {
      "config": "movablechat.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~26.1.2",
    "java": ">=25",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}